# ── Banco de dados ────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=change_me_strong_password
MONGO_DB=homepet
MONGO_HOST=mongodb
MONGO_PORT=27017

# ── Autenticação JWT ──────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
SECRET_KEY=change_me_generate_a_256bit_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── API ───────────────────────────────────────────────────────────────
# Em produção: separar por vírgula se múltiplos
ALLOWED_ORIGINS=["http://localhost","http://localhost:80","http://localhost:5173"]
DEBUG=false

# ── Admin seed (primeiro deploy) ──────────────────────────────────────
# Se definidos, o backend cria o admin no primeiro boot (idempotente)
ADMIN_EMAIL=admin@homepet.com
ADMIN_PASSWORD=change_me_SenhaF0rte!@#
